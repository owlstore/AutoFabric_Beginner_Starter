{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "check:raw-button": "bash -lc \"if rg -n '<button|</button>' src -g '!**/*.bak' -g '!**/_backup*/**' -g '!**/.backup_fix/**'; then echo '[FAILED] Found raw <button> in src'; exit 1; else echo '[OK] No raw <button> in src'; fi\"",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:fullflow": "playwright test --grep @fullflow",
    "test:e2e:headed": "playwright test --headed"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "highlight.js": "^11.11.1",
    "mermaid": "^11.13.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.58.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "vite": "^8.0.1"
  }
}
