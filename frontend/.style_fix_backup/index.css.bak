@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  color: #0f172a;
  background: #f1f5f9;
}

html, body, #root {
  margin: 0;
  min-height: 100%;
}

body {
  min-height: 100vh;
  background: #f1f5f9;
}
