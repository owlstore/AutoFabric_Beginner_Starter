import { useEffect, useMemo, useState } from "react";

const API_BASE = "http://127.0.0.1:8000";

async function apiGet(path) {
  const res = await fetch(`${API_BASE}${path}`);
  if (!res.ok) {
    const text = await res.text();
    throw new Error(`${res.status} ${text}`);
  }
  return res.json();
}

async function apiPost(path, body) {
  const res = await fetch(`${API_BASE}${path}`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json",
    },
    body: body ? JSON.stringify(body) : undefined,
  });

  if (!res.ok) {
    const text = await res.text();
    throw new Error(`${res.status} ${text}`);
  }

  return res.json();
}

function Badge({ children, tone = "default" }) {
  const toneClass = {
    default: "bg-slate-100 text-slate-700 border-slate-200",
    success: "bg-emerald-50 text-emerald-700 border-emerald-200",
    warning: "bg-amber-50 text-amber-700 border-amber-200",
    danger: "bg-red-50 text-red-700 border-red-200",
    info: "bg-blue-50 text-blue-700 border-blue-200",
    purple: "bg-violet-50 text-violet-700 border-violet-200",
  }[tone] || "bg-slate-100 text-slate-700 border-slate-200";

  return (
    <span
      className={`inline-flex items-center rounded-full border px-2.5 py-1 text-xs font-medium ${toneClass}`}
    >
      {children}
    </span>
  );
}

function SectionCard({ title, extra, children }) {
  return (
    <div className="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
      <div className="mb-4 flex items-start justify-between gap-3">
        <h3 className="text-base font-semibold text-slate-900">{title}</h3>
        {extra ? <div>{extra}</div> : null}
      </div>
      {children}
    </div>
  );
}

function KV({ label, value }) {
  return (
    <div className="grid grid-cols-[120px_1fr] gap-3 py-1.5">
      <div className="text-sm text-slate-500">{label}</div>
      <div className="text-sm text-slate-900 break-all">
        {value === null || value === undefined || value === "" ? "—" : String(value)}
      </div>
    </div>
  );
}

function JsonBlock({ data }) {
  return (
    <pre className="max-h-[420px] overflow-auto rounded-xl bg-slate-950 p-4 text-xs leading-6 text-slate-100">
      {JSON.stringify(data, null, 2)}
    </pre>
  );
}

function getStatusTone(status) {
  if (!status) return "default";
  const s = String(status).toLowerCase();
  if (["completed", "passed", "success"].includes(s)) return "success";
  if (["failed", "error"].includes(s)) return "danger";
  if (["in_progress", "running"].includes(s)) return "info";
  if (["draft", "pending"].includes(s)) return "warning";
  return "default";
}

function formatDate(value) {
  if (!value) return "—";
  try {
    return new Date(value).toLocaleString();
  } catch {
    return String(value);
  }
}

function parseTimelineIntoSections(timeline) {
  if (!timeline) {
    return {
      executions: [],
      artifacts: [],
      verifications: [],
      events: [],
    };
  }

  return {
    executions: Array.isArray(timeline.executions) ? timeline.executions : [],
    artifacts: Array.isArray(timeline.artifacts) ? timeline.artifacts : [],
    verifications: Array.isArray(timeline.verifications) ? timeline.verifications : [],
    events: Array.isArray(timeline.events) ? timeline.events : [],
  };
}

function WorkspaceListItem({ item, active, onClick }) {
  const latestOutcome = item.latest_outcome || {};
  const verificationStatus =
    latestOutcome?.current_result?.verification?.status || latestOutcome?.status;
  const executionStatus = latestOutcome?.current_result?.last_executor_run?.status;
  const artifact = latestOutcome?.current_result?.artifact;

  return (
    <button
      onClick={onClick}
      className={`w-full rounded-2xl border p-4 text-left transition ${
        active
          ? "border-slate-900 bg-slate-50 shadow-sm"
          : "border-slate-200 bg-white hover:border-slate-300 hover:bg-slate-50"
      }`}
    >
      <div className="mb-2 flex items-start justify-between gap-3">
        <div className="min-w-0">
          <div className="truncate text-sm font-semibold text-slate-900">{item.title}</div>
          <div className="mt-1 text-xs text-slate-500">Goal #{item.goal_id}</div>
        </div>
        <Badge tone={getStatusTone(item.stage)}>{item.stage || "unknown"}</Badge>
      </div>

      <div className="mb-3 flex flex-wrap gap-2">
        <Badge tone="purple">{item.goal_type || "unknown"}</Badge>
        <Badge tone="default">{item.scope || "unspecified"}</Badge>
        <Badge tone={getStatusTone(item.risk_level)}>{item.risk_level || "low"}</Badge>
      </div>

      <div className="space-y-1 text-xs text-slate-600">
        <div>Step: {item.step_type || "—"}</div>
        <div>Execution: {executionStatus || "—"}</div>
        <div>Verification: {verificationStatus || "—"}</div>
        <div>Artifact: {artifact?.image_tag || artifact?.type || "—"}</div>
      </div>
    </button>
  );
}

function ExecutionList({ items }) {
  if (!items.length) {
    return <div className="text-sm text-slate-500">No execution records yet.</div>;
  }

  return (
    <div className="space-y-4">
      {items.map((item) => (
        <div key={item.id} className="rounded-xl border border-slate-200 p-4">
          <div className="mb-3 flex flex-wrap items-center gap-2">
            <Badge tone={getStatusTone(item.status)}>{item.status}</Badge>
            <Badge tone="info">{item.executor_name}</Badge>
            <Badge tone="default">{item.task_name || "task"}</Badge>
          </div>
          <KV label="Started" value={formatDate(item.started_at)} />
          <KV label="Finished" value={formatDate(item.finished_at)} />
          <KV label="Created" value={formatDate(item.created_at)} />
          <div className="mt-3 grid gap-4 lg:grid-cols-2">
            <div>
              <div className="mb-2 text-sm font-medium text-slate-700">Input</div>
              <JsonBlock data={item.input_payload} />
            </div>
            <div>
              <div className="mb-2 text-sm font-medium text-slate-700">Output</div>
              <JsonBlock data={item.output_payload} />
            </div>
          </div>
        </div>
      ))}
    </div>
  );
}

function ArtifactList({ items }) {
  if (!items.length) {
    return <div className="text-sm text-slate-500">No artifact records yet.</div>;
  }

  return (
    <div className="space-y-4">
      {items.map((item) => (
        <div key={item.id} className="rounded-xl border border-slate-200 p-4">
          <div className="mb-3 flex flex-wrap items-center gap-2">
            <Badge tone="success">{item.artifact_type}</Badge>
            <Badge tone="default">{item.artifact_ref || "artifact"}</Badge>
          </div>
          <KV label="File Path" value={item.file_path} />
          <KV label="Created" value={formatDate(item.created_at)} />
          <div className="mt-3">
            <div className="mb-2 text-sm font-medium text-slate-700">Metadata</div>
            <JsonBlock data={item.metadata} />
          </div>
        </div>
      ))}
    </div>
  );
}

function VerificationList({ items }) {
  if (!items.length) {
    return <div className="text-sm text-slate-500">No verification records yet.</div>;
  }

  return (
    <div className="space-y-4">
      {items.map((item) => (
        <div key={item.id} className="rounded-xl border border-slate-200 p-4">
          <div className="mb-3 flex flex-wrap items-center gap-2">
            <Badge tone={getStatusTone(item.status)}>{item.status}</Badge>
            <Badge tone="info">{item.verifier_name}</Badge>
          </div>
          <KV label="Verified At" value={formatDate(item.verified_at)} />
          <KV label="Created" value={formatDate(item.created_at)} />
          <div className="mt-3 grid gap-4 lg:grid-cols-2">
            <div>
              <div className="mb-2 text-sm font-medium text-slate-700">Summary</div>
              <JsonBlock data={item.summary} />
            </div>
            <div>
              <div className="mb-2 text-sm font-medium text-slate-700">Checks</div>
              <JsonBlock data={item.checks} />
            </div>
          </div>
        </div>
      ))}
    </div>
  );
}

function TimelineEvents({ items }) {
  if (!items.length) {
    return <div className="text-sm text-slate-500">No timeline events yet.</div>;
  }

  return (
    <div className="space-y-4">
      {items.map((event, idx) => (
        <div key={`${event.type}-${idx}`} className="rounded-xl border border-slate-200 p-4">
          <div className="mb-3 flex flex-wrap items-center gap-2">
            <Badge tone="purple">{event.type}</Badge>
            <Badge tone="default">{formatDate(event.at)}</Badge>
          </div>
          <JsonBlock data={event.payload} />
        </div>
      ))}
    </div>
  );
}

export default function App() {
  const [input, setInput] = useState("Build an Ubuntu 22.04 development environment with Docker Git Python");
  const [workspaces, setWorkspaces] = useState([]);
  const [selectedGoalId, setSelectedGoalId] = useState(null);
  const [timeline, setTimeline] = useState(null);
  const [loadingList, setLoadingList] = useState(false);
  const [loadingTimeline, setLoadingTimeline] = useState(false);
  const [submitting, setSubmitting] = useState(false);
  const [acting, setActing] = useState(false);
  const [error, setError] = useState("");

  const selectedWorkspace = useMemo(
    () => workspaces.find((w) => w.goal_id === selectedGoalId) || workspaces[0] || null,
    [workspaces, selectedGoalId]
  );

  const selectedOutcomeId = selectedWorkspace?.latest_outcome?.id || null;

  const parsedSections = useMemo(() => parseTimelineIntoSections(timeline), [timeline]);

  async function loadWorkspaces(preferredGoalId = null) {
    try {
      setLoadingList(true);
      setError("");
      const data = await apiGet("/workspaces");
      const items = Array.isArray(data.items) ? data.items : [];
      setWorkspaces(items);

      const nextGoalId =
        preferredGoalId ||
        (items.some((x) => x.goal_id === selectedGoalId) ? selectedGoalId : items[0]?.goal_id) ||
        null;

      setSelectedGoalId(nextGoalId);
    } catch (err) {
      setError(err.message || "Failed to load workspaces.");
    } finally {
      setLoadingList(false);
    }
  }

  async function loadTimeline(outcomeId) {
    if (!outcomeId) {
      setTimeline(null);
      return;
    }

    try {
      setLoadingTimeline(true);
      setError("");
      const data = await apiGet(`/outcomes/${outcomeId}/timeline`);
      setTimeline(data);
    } catch (err) {
      setTimeline(null);
      setError(err.message || "Failed to load timeline.");
    } finally {
      setLoadingTimeline(false);
    }
  }

  async function handleSubmit(e) {
    e.preventDefault();
    if (!input.trim()) return;

    try {
      setSubmitting(true);
      setError("");
      await apiPost("/entry/submit", { user_input: input.trim() });
      await loadWorkspaces();
    } catch (err) {
      setError(err.message || "Submit failed.");
    } finally {
      setSubmitting(false);
    }
  }

  async function handleExecute() {
    if (!selectedOutcomeId) return;
    try {
      setActing(true);
      setError("");
      await apiPost(`/outcomes/${selectedOutcomeId}/execute`);
      await loadWorkspaces(selectedWorkspace?.goal_id);
      await loadTimeline(selectedOutcomeId);
    } catch (err) {
      setError(err.message || "Execute failed.");
    } finally {
      setActing(false);
    }
  }

  async function handleVerify() {
    if (!selectedOutcomeId) return;
    try {
      setActing(true);
      setError("");
      await apiPost(`/outcomes/${selectedOutcomeId}/verify`);
      await loadWorkspaces(selectedWorkspace?.goal_id);
      await loadTimeline(selectedOutcomeId);
    } catch (err) {
      setError(err.message || "Verify failed.");
    } finally {
      setActing(false);
    }
  }

  useEffect(() => {
    loadWorkspaces();
  }, []);

  useEffect(() => {
    if (selectedWorkspace?.latest_outcome?.id) {
      loadTimeline(selectedWorkspace.latest_outcome.id);
    } else {
      setTimeline(null);
    }
  }, [selectedWorkspace?.latest_outcome?.id]);

  return (
    <div className="min-h-screen bg-slate-100 text-slate-900">
      <div className="mx-auto max-w-[1600px] px-4 py-6 lg:px-6">
        <div className="mb-6 rounded-3xl border border-slate-200 bg-white p-6 shadow-sm">
          <div className="mb-4 flex flex-col gap-2 lg:flex-row lg:items-center lg:justify-between">
            <div>
              <h1 className="text-2xl font-bold tracking-tight">AutoFabric Workspace</h1>
              <p className="mt-1 text-sm text-slate-500">
                Goal → Outcome → Execute → Verify → Audit Timeline
              </p>
            </div>
            <div className="flex flex-wrap gap-2">
              <Badge tone="success">Audit Ready</Badge>
              <Badge tone="info">Timeline Ready</Badge>
            </div>
          </div>

          <form onSubmit={handleSubmit} className="grid gap-3 lg:grid-cols-[1fr_auto]">
            <input
              value={input}
              onChange={(e) => setInput(e.target.value)}
              placeholder="Describe the outcome you want to build..."
              className="h-12 rounded-2xl border border-slate-300 px-4 text-sm outline-none ring-0 transition focus:border-slate-500"
            />
            <button
              type="submit"
              disabled={submitting}
              className="h-12 rounded-2xl bg-slate-900 px-5 text-sm font-medium text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
            >
              {submitting ? "Submitting..." : "Submit Goal"}
            </button>
          </form>

          {error ? (
            <div className="mt-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
              {error}
            </div>
          ) : null}
        </div>

        <div className="grid gap-6 xl:grid-cols-[360px_minmax(0,1fr)]">
          <div className="space-y-4">
            <div className="flex items-center justify-between">
              <h2 className="text-sm font-semibold uppercase tracking-wide text-slate-500">
                Workspaces
              </h2>
              <Badge tone="default">{loadingList ? "Loading..." : `${workspaces.length} items`}</Badge>
            </div>

            <div className="space-y-3">
              {workspaces.map((item) => (
                <WorkspaceListItem
                  key={item.goal_id}
                  item={item}
                  active={selectedWorkspace?.goal_id === item.goal_id}
                  onClick={() => setSelectedGoalId(item.goal_id)}
                />
              ))}
            </div>
          </div>

          <div className="space-y-6">
            {!selectedWorkspace ? (
              <div className="rounded-3xl border border-slate-200 bg-white p-8 text-sm text-slate-500 shadow-sm">
                No workspace selected.
              </div>
            ) : (
              <>
                <SectionCard
                  title="Workspace Overview"
                  extra={
                    <div className="flex flex-wrap gap-2">
                      <button
                        onClick={handleExecute}
                        disabled={acting || !selectedOutcomeId}
                        className="rounded-xl bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
                      >
                        {acting ? "Working..." : "Execute"}
                      </button>
                      <button
                        onClick={handleVerify}
                        disabled={acting || !selectedOutcomeId}
                        className="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-800 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-60"
                      >
                        Verify
                      </button>
                    </div>
                  }
                >
                  <div className="mb-4 flex flex-wrap gap-2">
                    <Badge tone="purple">{selectedWorkspace.goal_type}</Badge>
                    <Badge tone={getStatusTone(selectedWorkspace.stage)}>{selectedWorkspace.stage}</Badge>
                    <Badge tone="default">{selectedWorkspace.scope || "unspecified"}</Badge>
                    <Badge tone={getStatusTone(selectedWorkspace.risk_level)}>{selectedWorkspace.risk_level}</Badge>
                    <Badge tone={getStatusTone(selectedWorkspace.latest_outcome?.status)}>
                      {selectedWorkspace.latest_outcome?.status || "unknown"}
                    </Badge>
                  </div>

                  <KV label="Goal ID" value={selectedWorkspace.goal_id} />
                  <KV label="Title" value={selectedWorkspace.title} />
                  <KV label="Step Type" value={selectedWorkspace.step_type} />
                  <KV label="Created" value={formatDate(selectedWorkspace.created_at)} />
                  <KV label="Updated" value={formatDate(selectedWorkspace.updated_at)} />

                  <div className="mt-4 grid gap-4 lg:grid-cols-2">
                    <div>
                      <div className="mb-2 text-sm font-medium text-slate-700">Latest Outcome</div>
                      <JsonBlock data={selectedWorkspace.latest_outcome} />
                    </div>
                    <div>
                      <div className="mb-2 text-sm font-medium text-slate-700">Timeline Summary</div>
                      <JsonBlock data={timeline?.summary || { loading: loadingTimeline }} />
                    </div>
                  </div>
                </SectionCard>

                <SectionCard
                  title="Executions"
                  extra={<Badge tone="info">{parsedSections.executions.length}</Badge>}
                >
                  <ExecutionList items={parsedSections.executions} />
                </SectionCard>

                <SectionCard
                  title="Artifacts"
                  extra={<Badge tone="success">{parsedSections.artifacts.length}</Badge>}
                >
                  <ArtifactList items={parsedSections.artifacts} />
                </SectionCard>

                <SectionCard
                  title="Verifications"
                  extra={<Badge tone="success">{parsedSections.verifications.length}</Badge>}
                >
                  <VerificationList items={parsedSections.verifications} />
                </SectionCard>

                <SectionCard
                  title="Timeline Events"
                  extra={<Badge tone="default">{parsedSections.events.length}</Badge>}
                >
                  {loadingTimeline ? (
                    <div className="text-sm text-slate-500">Loading timeline...</div>
                  ) : (
                    <TimelineEvents items={parsedSections.events} />
                  )}
                </SectionCard>

                <SectionCard title="Raw Timeline JSON">
                  <JsonBlock data={timeline} />
                </SectionCard>
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}