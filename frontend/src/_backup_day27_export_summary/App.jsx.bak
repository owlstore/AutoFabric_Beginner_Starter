            <div>
              <div className="mb-2 text-sm font-medium text-slate-700">摘要</div>
              <JsonBlock data={item.summary} />
            </div>
            <div>
              <div className="mb-2 text-sm font-medium text-slate-700">检查项</div>
              <JsonBlock data={item.checks} />
