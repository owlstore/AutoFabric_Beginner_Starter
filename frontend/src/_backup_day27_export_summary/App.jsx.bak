}

function PresetScenarioCard({ item, onApply }) {
  return (
    <button
      onClick={() => onApply(item)}
      className="rounded-2xl border border-slate-200 bg-white p-4 text-left transition hover:border-violet-300 hover:bg-violet-50"
    >
      <div className="text-sm font-semibold text-slate-900">{item.label}</div>
      <div className="mt-2 text-xs leading-5 text-slate-500">{item.description}</div>
    </button>
  );
}

function OpenClawPanel({
  selectedTemplateId,
  setSelectedTemplateId,
  openclawUrl,
  setOpenclawUrl,
  openclawIssue,
  setOpenclawIssue,
  openclawAccountHint,
  setOpenclawAccountHint,
  onExecute,
  onApplySuggested,
  onApplyPresetScenario,
  onResetFields,
  onClearFields,
  onRestoreDraft,
  hasOpenclawDraft,
  executing,
  disabled,
  currentTemplate,
  latestOpenclawSummary,
  suggestedTemplate,
  openclawNotice,
}) {
  return (
    <SectionCard title="OpenClaw 执行面板" extra={<Badge tone="purple">Browser Executor</Badge>}>
      <div className="grid gap-5">
        <div>
          <div className="mb-2 text-sm font-medium text-slate-700">常用场景</div>
          <div className="grid gap-3 md:grid-cols-3">
            {OPENCLAW_PRESET_SCENARIOS.map((item) => (
              <PresetScenarioCard key={item.id} item={item} onApply={onApplyPresetScenario} />
            ))}
          </div>
        </div>

        {suggestedTemplate ? (
          <div className="rounded-2xl border border-violet-200 bg-violet-50 p-4">
            <div className="mb-2 flex flex-wrap items-center gap-2">
              <Badge tone="purple">推荐模板</Badge>
              <Badge tone="info">{suggestedTemplate.templateId}</Badge>
            </div>
            <div className="text-sm text-slate-700">{suggestedTemplate.reason}</div>
            <button
              onClick={onApplySuggested}
              className="mt-3 rounded-xl border border-violet-300 bg-white px-4 py-2 text-sm font-medium text-violet-700 hover:bg-violet-100"
            >
              应用推荐模板
            </button>
          </div>
        ) : null}

        <div className="grid gap-2">
          <label className="text-sm font-medium text-slate-700">任务模板</label>
          <select
            value={selectedTemplateId}
            onChange={(e) => setSelectedTemplateId(e.target.value)}
            className="h-11 rounded-2xl border border-slate-300 bg-white px-3 text-sm outline-none"
          >
            {OPENCLAW_TEMPLATES.map((item) => (
              <option key={item.id} value={item.id}>
                {item.label}
              </option>
            ))}
          </select>
          <div className="text-xs text-slate-500">{currentTemplate.description}</div>
        </div>

        <div className="grid gap-2">
          <label className="text-sm font-medium text-slate-700">目标 URL</label>
          <input
            value={openclawUrl}
            onChange={(e) => setOpenclawUrl(e.target.value)}
            className="h-11 rounded-2xl border border-slate-300 px-4 text-sm outline-none"
          />
        </div>

        <div className="grid gap-2">
          <label className="text-sm font-medium text-slate-700">问题描述</label>
          <textarea
            value={openclawIssue}
            onChange={(e) => setOpenclawIssue(e.target.value)}
            rows={3}
            className="rounded-2xl border border-slate-300 px-4 py-3 text-sm outline-none"
          />
        </div>

        <div className="grid gap-2">
          <label className="text-sm font-medium text-slate-700">账号提示</label>
          <input
            value={openclawAccountHint}
            onChange={(e) => setOpenclawAccountHint(e.target.value)}
            className="h-11 rounded-2xl border border-slate-300 px-4 text-sm outline-none"
          />
        </div>

        <div className="flex flex-wrap gap-2">
          <button
            onClick={onResetFields}
            className="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
          >
            重置默认值
          </button>
          <button
            onClick={onClearFields}
            className="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
          >
            清空参数
          </button>
          <button
            onClick={onRestoreDraft}
            disabled={!hasOpenclawDraft}
            className="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-50"
          >
            恢复最近使用
          </button>
        </div>

        {openclawNotice ? (
          <div
            className={`rounded-2xl p-4 text-sm ${
              openclawNotice.type === "success"
                ? "border border-emerald-200 bg-emerald-50 text-emerald-700"
                : openclawNotice.type === "error"
                ? "border border-red-200 bg-red-50 text-red-700"
                : "border border-blue-200 bg-blue-50 text-blue-700"
            }`}
          >
            {openclawNotice.message}
          </div>
        ) : null}

        {latestOpenclawSummary ? (
          <div className="rounded-2xl border border-violet-200 bg-violet-50 p-4">
            <div className="mb-2 flex items-center gap-2">
              <Badge tone="purple">最新结果</Badge>
              <Badge tone={getToneByStatus(latestOpenclawSummary.status)}>
                {mapStatusLabel(latestOpenclawSummary.status)}
              </Badge>
            </div>
            <div className="text-sm text-slate-700">{latestOpenclawSummary.message}</div>
          </div>
        ) : null}

        <button
          onClick={onExecute}
          disabled={executing || disabled}
          className="rounded-2xl bg-violet-600 px-5 py-3 text-sm font-medium text-white hover:bg-violet-700 disabled:cursor-not-allowed disabled:opacity-60"
        >
          {executing ? "执行中..." : "使用 OpenClaw 执行"}
        </button>
      </div>
    </SectionCard>
  );
}

export default function App() {
  const [input, setInput] = useState("Build an Ubuntu 22.04 development environment with Docker Git Python");
  const [cards, setCards] = useState([]);
  const [selectedGoalId, setSelectedGoalId] = useState(null);
  const [detail, setDetail] = useState(null);
  const [timeline, setTimeline] = useState([]);
  const [loadingList, setLoadingList] = useState(false);
  const [loadingDetail, setLoadingDetail] = useState(false);
  const [acting, setActing] = useState(false);
  const [submitting, setSubmitting] = useState(false);
  const [error, setError] = useState("");
  const [activeTab, setActiveTab] = useState("overview");
  const [tabMemoryByGoal, setTabMemoryByGoal] = useState({});
  const [quickFilter, setQuickFilter] = useState("all");
  const [visibleCount, setVisibleCount] = useState(8);
  const [recentInputs, setRecentInputs] = useState([]);

  const [searchText, setSearchText] = useState("");
  const [statusFilter, setStatusFilter] = useState("all");
  const [goalTypeFilter, setGoalTypeFilter] = useState("all");
  const [sortOrder, setSortOrder] = useState("updated_desc");

  const [selectedTemplateId, setSelectedTemplateId] = useState(OPENCLAW_TEMPLATES[0].id);
  const [openclawUrl, setOpenclawUrl] = useState(OPENCLAW_TEMPLATES[0].defaults.url);
  const [openclawIssue, setOpenclawIssue] = useState(OPENCLAW_TEMPLATES[0].defaults.issue);
  const [openclawAccountHint, setOpenclawAccountHint] = useState(OPENCLAW_TEMPLATES[0].defaults.account_hint);
  const [openclawActing, setOpenclawActing] = useState(false);
  const [openclawNotice, setOpenclawNotice] = useState(null);
  const [hasOpenclawDraft, setHasOpenclawDraft] = useState(false);
  const [copiedHint, setCopiedHint] = useState("");
  const [expandedFields, setExpandedFields] = useState({
    goal: false,
    result: false,
    next: false,
  });


  const currentTemplate = useMemo(
    () => getOpenclawTemplateById(selectedTemplateId),
    [selectedTemplateId]
  );

  const suggestedTemplate = useMemo(
    () => getRecommendedOpenclawTemplate(detail),
    [detail]
  );

  const filteredCards = useMemo(() => {
    let result = [...cards];

    if (searchText.trim()) {
      const q = searchText.trim().toLowerCase();
      result = result.filter((item) =>
        [item.title, item.status, item.goal_type, item.current_result_summary, item.next_action_summary]
          .filter(Boolean)
          .some((v) => String(v).toLowerCase().includes(q))
      );
    }

    if (statusFilter !== "all") {
      result = result.filter((item) => String(item.status || "").toLowerCase() === statusFilter);
    }

    if (goalTypeFilter !== "all") {
      result = result.filter((item) => String(item.goal_type || "").toLowerCase() === goalTypeFilter);
    }

    if (quickFilter === "completed") {
      result = result.filter((item) =>
        ["completed", "ready", "passed", "success"].includes(String(item.status || "").toLowerCase())
      );
    }

    if (quickFilter === "running") {
      result = result.filter((item) =>
        ["building", "running", "in_progress", "verifying"].includes(String(item.status || "").toLowerCase())
      );
    }

    if (quickFilter === "failed") {
      result = result.filter((item) =>
        ["failed", "error"].includes(String(item.status || "").toLowerCase())
      );
    }

    if (quickFilter === "openclaw") {
      result = result.filter((item) => {
        const t1 = String(item.current_result_summary || "").toLowerCase();
        const t2 = String(item.next_action_summary || "").toLowerCase();
        const t3 = String(item.stage || "").toLowerCase();
        return t1.includes("openclaw") || t2.includes("openclaw") || t3.includes("browser");
      });
    }

    result.sort((a, b) => {
      if (sortOrder === "title_asc") return String(a.title || "").localeCompare(String(b.title || ""));
      if (sortOrder === "title_desc") return String(b.title || "").localeCompare(String(a.title || ""));
      const ta = new Date(a.updated_at || 0).getTime();
      const tb = new Date(b.updated_at || 0).getTime();
      if (sortOrder === "updated_asc") return ta - tb;
      return tb - ta;
    });

    return result;
  }, [cards, searchText, statusFilter, goalTypeFilter, sortOrder, quickFilter]);

  const visibleCards = useMemo(() => {
    return filteredCards.slice(0, visibleCount);
  }, [filteredCards, visibleCount]);

  const hasMoreCards = filteredCards.length > visibleCount;

  const activeCard = useMemo(() => {
    return (
      filteredCards.find((item) => item.goal_id === selectedGoalId) ||
      cards.find((item) => item.goal_id === selectedGoalId) ||
      filteredCards[0] ||
      cards[0] ||
      null
    );
  }, [filteredCards, cards, selectedGoalId]);

  const statusOptions = useMemo(() => {
    const values = Array.from(new Set(cards.map((item) => String(item.status || "unknown").toLowerCase())));
    return ["all", ...values];
  }, [cards]);

  const goalTypeOptions = useMemo(() => {
    const values = Array.from(new Set(cards.map((item) => String(item.goal_type || "unknown").toLowerCase())));
    return ["all", ...values];
  }, [cards]);

  const metrics = useMemo(() => {
    const total = cards.length;
    const completed = cards.filter((x) =>
      ["completed", "ready", "passed", "success"].includes(String(x.status || "").toLowerCase())
    ).length;
    const running = cards.filter((x) =>
      ["building", "running", "in_progress", "verifying"].includes(String(x.status || "").toLowerCase())
    ).length;
    const failed = cards.filter((x) =>
      ["failed", "error"].includes(String(x.status || "").toLowerCase())
    ).length;
    return { total, completed, running, failed };
  }, [cards]);

  const activeOutcomeId = detail?.latest_outcome?.id || activeCard?.outcome_id || null;

  const latestOpenclawSummary = useMemo(() => {
    const executions = detail?.executions || [];
    const latest = executions.find((item) => item.executor_name === "openclaw");
    if (!latest) return null;
    return {
      status: latest.status,
      message:
        latest.output_payload?.stdout?.message ||
        latest.output_payload?.message ||
        `OpenClaw task ${latest.task_name} finished with status ${latest.status}.`,
    };
  }, [detail]);

  async function reloadList(preferredGoalId = null) {
    try {
      setLoadingList(true);
      setError("");
      const data = await loadOutcomeWorkbenchList();
      const items = adaptWorkspaceListToOutcomeCards(data.items || []);
      setCards(items);
      const nextGoalId =
        preferredGoalId ||
        (items.some((x) => x.goal_id === selectedGoalId) ? selectedGoalId : items[0]?.goal_id) ||
        null;
      setSelectedGoalId(nextGoalId);
    } catch (err) {
      setError(err.message || "加载结果清单失败");
    } finally {
      setLoadingList(false);
    }
  }

  async function reloadDetail(goalId) {
    if (!goalId) {
      setDetail(null);
      return;
    }
    try {
      setLoadingDetail(true);
      setError("");
      const data = await loadOutcomeWorkbenchDetail(goalId);
      const adapted = adaptWorkspaceDetailToOutcomeDetail(data);
      setDetail(adapted);
    } catch (err) {
      setDetail(null);
      setError(err.message || "加载结果详情失败");
    } finally {
      setLoadingDetail(false);
    }
  }

  async function reloadTimeline(outcomeId) {
    if (!outcomeId) {
      setTimeline([]);
      return;
    }
    try {
      const data = await loadOutcomeTimeline(outcomeId);
      setTimeline(Array.isArray(data.items) ? data.items : []);
    } catch (err) {
      setTimeline([]);
      setError(err.message || "加载流程事件失败");
    }
  }

  async function handleSubmit(e) {
    e.preventDefault();
    const trimmed = input.trim();
    if (!trimmed) return;
    try {
      setSubmitting(true);
      setError("");
      await submitEntry({ user_input: trimmed });

      setRecentInputs((prev) => {
        const next = [trimmed, ...prev.filter((item) => item !== trimmed)].slice(0, 6);
        try {
          localStorage.setItem("autofabric_recent_inputs", JSON.stringify(next));
        } catch {}
        return next;
      });

      await reloadList();
    } catch (err) {
      setError(err.message || "提交目标失败");
    } finally {
      setSubmitting(false);
    }
  }

  async function handleExecute() {
    if (!activeOutcomeId) return;
    try {
      setActing(true);
      setError("");
      await triggerOutcomeExecute(activeOutcomeId);
      await reloadList(selectedGoalId);
      await reloadDetail(selectedGoalId);
      await reloadTimeline(activeOutcomeId);
    } catch (err) {
      setError(err.message || "执行失败");
    } finally {
      setActing(false);
    }
  }

  async function handleOpenClawExecute() {
    if (!activeOutcomeId) return;
    try {
      setOpenclawActing(true);
      setError("");
      setOpenclawNotice(null);

      await triggerOutcomeExecute(activeOutcomeId, {
        executor_type: "openclaw",
        task_name: currentTemplate.task_name,
        payload: {
          url: openclawUrl,
          issue: openclawIssue,
          account_hint: openclawAccountHint,
        },
      });

      await reloadList(selectedGoalId);
      await reloadDetail(selectedGoalId);
      await reloadTimeline(activeOutcomeId);

      setActiveTab("openclaw");
      setOpenclawNotice({
        type: "success",
        message: "OpenClaw 执行成功，结果与证据已刷新。",
      });
    } catch (err) {
      const msg = err.message || "OpenClaw 执行失败";
      setError(msg);
      setOpenclawNotice({
        type: "error",
        message: msg,
      });
    } finally {
      setOpenclawActing(false);
    }
  }

  function handleApplySuggestedTemplate() {
    if (!suggestedTemplate?.templateId) return;
    setSelectedTemplateId(suggestedTemplate.templateId);
    setActiveTab("openclaw");
    setOpenclawNotice({
      type: "info",
      message: "已应用推荐模板，请检查参数后执行。",
    });
  }

  function handleApplyPresetScenario(item) {
    setSelectedTemplateId(item.templateId);
    setOpenclawUrl(item.url);
    setOpenclawIssue(item.issue);
    setOpenclawAccountHint(item.account_hint);
    setActiveTab("openclaw");
    setOpenclawNotice({
      type: "info",
      message: `已应用预设场景：${item.label}`,
    });
  }

  function resetOpenClawFields() {
    const tpl = getOpenclawTemplateById(selectedTemplateId);
    setOpenclawUrl(tpl.defaults.url || "");
    setOpenclawIssue(tpl.defaults.issue || "");
    setOpenclawAccountHint(tpl.defaults.account_hint || "");
    setOpenclawNotice({
      type: "info",
      message: "已重置为当前模板默认参数。",
    });
  }

  function clearOpenClawFields() {
    setOpenclawUrl("");
    setOpenclawIssue("");
    setOpenclawAccountHint("");
    setOpenclawNotice({
      type: "info",
      message: "已清空 OpenClaw 参数。",
    });
  }

  function restoreLastOpenClawDraft() {
    try {
      const raw = localStorage.getItem("autofabric_openclaw_last_used");
      if (!raw) {
        setOpenclawNotice({
          type: "info",
          message: "没有可恢复的最近使用记录。",
        });
        return;
      }
      const parsed = JSON.parse(raw);
      if (parsed.templateId) setSelectedTemplateId(parsed.templateId);
      setOpenclawUrl(parsed.url || "");
      setOpenclawIssue(parsed.issue || "");
      setOpenclawAccountHint(parsed.account_hint || "");
      setHasOpenclawDraft(true);
      setOpenclawNotice({
        type: "info",
        message: "已恢复最近一次使用的 OpenClaw 参数。",
      });
    } catch {
      setOpenclawNotice({
        type: "error",
        message: "恢复最近使用参数失败。",
      });
    }
  }

  function handleTabChange(nextTab) {
    setActiveTab(nextTab);
    if (selectedGoalId) {
      setTabMemoryByGoal((prev) => ({
        ...prev,
        [selectedGoalId]: nextTab,
      }));
    }
  }

  async function copyText(value, label) {
    try {
      await navigator.clipboard.writeText(String(value || ""));
      setCopiedHint(`${label} 已复制`);
      setTimeout(() => setCopiedHint(""), 1500);
    } catch {
      setCopiedHint(`${label} 复制失败`);
      setTimeout(() => setCopiedHint(""), 1500);
    }
  }

  useEffect(() => {
    reloadList();
  }, []);

  useEffect(() => {
    try {
      const raw = localStorage.getItem("autofabric_recent_inputs");
      if (!raw) return;
      const parsed = JSON.parse(raw);
      if (Array.isArray(parsed)) {
        setRecentInputs(parsed.slice(0, 6));
      }
    } catch {}
  }, []);

  useEffect(() => {
    try {
      const raw = localStorage.getItem("autofabric_openclaw_last_used");
      if (!raw) return;
      const parsed = JSON.parse(raw);
      if (parsed.templateId) setSelectedTemplateId(parsed.templateId);
      setOpenclawUrl(parsed.url || "");
      setOpenclawIssue(parsed.issue || "");
      setOpenclawAccountHint(parsed.account_hint || "");
      setHasOpenclawDraft(true);
    } catch {}
  }, []);

  useEffect(() => {
    const payload = {
      templateId: selectedTemplateId,
      url: openclawUrl,
      issue: openclawIssue,
      account_hint: openclawAccountHint,
    };
    try {
      localStorage.setItem("autofabric_openclaw_last_used", JSON.stringify(payload));
      setHasOpenclawDraft(Boolean(openclawUrl || openclawIssue || openclawAccountHint));
    } catch {}
  }, [selectedTemplateId, openclawUrl, openclawIssue, openclawAccountHint]);

  useEffect(() => {
    const tpl = getOpenclawTemplateById(selectedTemplateId);
    setOpenclawUrl((prev) => (prev ? prev : tpl.defaults.url || ""));
    setOpenclawIssue((prev) => (prev ? prev : tpl.defaults.issue || ""));
    setOpenclawAccountHint((prev) => (prev ? prev : tpl.defaults.account_hint || ""));
  }, [selectedTemplateId]);

  useEffect(() => {
    if (!selectedGoalId && cards.length > 0) {
      setSelectedGoalId(cards[0].goal_id);
      return;
    }
    if (activeCard?.goal_id && activeCard.goal_id !== selectedGoalId) {
      setSelectedGoalId(activeCard.goal_id);
    }
  }, [activeCard?.goal_id, selectedGoalId, cards]);

  useEffect(() => {
    if (selectedGoalId) {
      reloadDetail(selectedGoalId);
    }
  }, [selectedGoalId]);

  useEffect(() => {
    if (detail?.latest_outcome?.id) {
      reloadTimeline(detail.latest_outcome.id);
    } else if (activeCard?.outcome_id) {
      reloadTimeline(activeCard.outcome_id);
    } else {
      setTimeline([]);
    }
  }, [detail?.latest_outcome?.id, activeCard?.outcome_id]);

  useEffect(() => {
    if (!selectedGoalId) return;
    const remembered = tabMemoryByGoal[selectedGoalId];
    if (remembered) {
      setActiveTab(remembered);
      return;
    }
    if (detail && shouldPreferOpenClawTab(detail)) {
      setActiveTab("openclaw");
      return;
    }
    setActiveTab("overview");
  }, [selectedGoalId, detail, tabMemoryByGoal]);

  useEffect(() => {
    setVisibleCount(8);
  }, [searchText, statusFilter, goalTypeFilter, sortOrder, quickFilter]);

  useEffect(() => {
    setExpandedFields({
      goal: false,
      result: false,
      next: false,
    });
  }, [selectedGoalId]);



  return (
    <div className="min-h-screen bg-slate-100 text-slate-900">
      <div className="mx-auto max-w-[1440px] px-6 py-8">
        <div className="mb-6 rounded-3xl border border-slate-200 bg-white p-8 shadow-sm">
          <div className="mb-4 flex flex-col gap-2">
            <h1 className="text-5xl font-bold tracking-tight text-slate-900">AutoFabric 成果工作台</h1>
            <p className="text-lg text-slate-600">目标 → 结果 → 执行 → 流程事件 → 证据</p>
            <p className="text-base text-slate-500">以结果为导向的审计追踪准备就绪</p>
          </div>

          <form onSubmit={handleSubmit} className="grid gap-3 lg:grid-cols-[1fr_auto]">
            <input
              value={input}
              onChange={(e) => setInput(e.target.value)}
              placeholder="描述你要构建的结果..."
              className="h-12 rounded-2xl border border-slate-300 px-4 text-sm outline-none transition focus:border-slate-500"
            />
            <button
              type="submit"
              disabled={submitting}
              className="h-12 rounded-2xl bg-slate-900 px-5 text-sm font-medium text-white transition hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
            >
              {submitting ? "提交中..." : "提交目标"}
            </button>
          </form>

          {recentInputs.length ? (
            <div className="mt-4">
              <div className="mb-2 text-xs font-medium uppercase tracking-wide text-slate-500">最近提交</div>
              <div className="flex flex-wrap gap-2">
                {recentInputs.map((item) => (
                  <button
                    key={item}
                    onClick={() => setInput(item)}
                    className="max-w-full rounded-full border border-slate-200 bg-white px-3 py-2 text-left text-xs text-slate-700 transition hover:bg-slate-50"
                    title={item}
                  >
                    {item.length > 48 ? `${item.slice(0, 48)}...` : item}
                  </button>
                ))}
              </div>
            </div>
          ) : null}

          {copiedHint ? (
            <div className="mt-4 rounded-2xl border border-blue-200 bg-blue-50 px-4 py-3 text-sm text-blue-700">
              {copiedHint}
            </div>
          ) : null}

          {error ? (
            <div className="mt-4 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-sm text-red-700">
              {error}
            </div>
          ) : null}
        </div>

        <div className="mb-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
          <MetricCard
            label="结果总数"
            value={metrics.total}
            active={quickFilter === "all"}
            onClick={() => setQuickFilter("all")}
          />
          <MetricCard
            label="已完成"
            value={metrics.completed}
            tone="success"
            active={quickFilter === "completed"}
            onClick={() => setQuickFilter("completed")}
          />
          <MetricCard
            label="执行中"
            value={metrics.running}
            tone="info"
            active={quickFilter === "running"}
            onClick={() => setQuickFilter("running")}
          />
          <MetricCard
            label="失败"
            value={metrics.failed}
            tone="danger"
            active={quickFilter === "failed"}
            onClick={() => setQuickFilter("failed")}
          />
        </div>

        <div className="grid grid-cols-1 gap-6 xl:grid-cols-[380px_minmax(0,1fr)]">
          <div className="space-y-4">
            <SectionCard
              title="结果清单"
              extra={<Badge tone="default">{loadingList ? "加载中..." : `${visibleCards.length} 条 / ${filteredCards.length} 条`}</Badge>}
            >
              <div className="space-y-3">
                <div className="sticky top-0 z-10 -mx-1 rounded-2xl bg-white px-1 pb-3">
                  <div className="flex flex-wrap gap-2">
                    <QuickFilterChip active={quickFilter === "all"} onClick={() => setQuickFilter("all")}>全部</QuickFilterChip>
                    <QuickFilterChip active={quickFilter === "completed"} onClick={() => setQuickFilter("completed")}>已完成</QuickFilterChip>
                    <QuickFilterChip active={quickFilter === "running"} onClick={() => setQuickFilter("running")}>执行中</QuickFilterChip>
                    <QuickFilterChip active={quickFilter === "failed"} onClick={() => setQuickFilter("failed")}>失败</QuickFilterChip>
                    <QuickFilterChip active={quickFilter === "openclaw"} onClick={() => setQuickFilter("openclaw")}>OpenClaw</QuickFilterChip>
                  </div>

                  <input
                    value={searchText}
                    onChange={(e) => setSearchText(e.target.value)}
                    placeholder="搜索标题/状态/结果/下一步"
                    className="mt-3 h-11 w-full rounded-2xl border border-slate-300 px-4 text-sm outline-none transition focus:border-slate-500"
                  />

                  <div className="mt-3 grid gap-3">
                    <select
                      value={statusFilter}
                      onChange={(e) => setStatusFilter(e.target.value)}
                      className="h-11 rounded-2xl border border-slate-300 bg-white px-3 text-sm outline-none"
                    >
                      {statusOptions.map((item) => (
                        <option key={item} value={item}>
                          {item === "all" ? "所有状态" : mapStatusLabel(item)}
                        </option>
                      ))}
                    </select>

                    <select
                      value={goalTypeFilter}
                      onChange={(e) => setGoalTypeFilter(e.target.value)}
                      className="h-11 rounded-2xl border border-slate-300 bg-white px-3 text-sm outline-none"
                    >
                      {goalTypeOptions.map((item) => (
                        <option key={item} value={item}>
                          {item === "all" ? "所有目标类型" : mapGoalTypeLabel(item)}
                        </option>
                      ))}
                    </select>

                    <select
                      value={sortOrder}
                      onChange={(e) => setSortOrder(e.target.value)}
                      className="h-11 rounded-2xl border border-slate-300 bg-white px-3 text-sm outline-none"
                    >
                      <option value="updated_desc">更新：最新</option>
                      <option value="updated_asc">更新：最早</option>
                      <option value="title_asc">标题：A → Z</option>
                      <option value="title_desc">标题：Z → A</option>
                    </select>
                  </div>
                </div>

                <div className="max-h-[980px] overflow-y-auto pr-1 space-y-3">
                  {visibleCards.map((item) => (
                    <OutcomeListItem
                      key={item.goal_id}
                      item={item}
                      active={activeCard?.goal_id === item.goal_id}
                      onClick={() => setSelectedGoalId(item.goal_id)}
                    />
                  ))}

                  {!filteredCards.length ? (
                    <div className="rounded-2xl border border-dashed border-slate-300 px-4 py-8 text-center text-sm text-slate-500">
                      没有符合筛选条件的结果。
                    </div>
                  ) : null}

                  {hasMoreCards ? (
                    <button
                      onClick={() => setVisibleCount((v) => v + 8)}
                      className="w-full rounded-2xl border border-slate-300 bg-white px-4 py-3 text-sm font-medium text-slate-700 transition hover:bg-slate-50"
                    >
                      加载更多（剩余 {filteredCards.length - visibleCount} 条）
                    </button>
                  ) : filteredCards.length > 8 ? (
                    <div className="rounded-2xl bg-slate-50 px-4 py-3 text-center text-xs text-slate-500">
                      已显示全部 {filteredCards.length} 条结果
                    </div>
                  ) : null}
                </div>
              </div>
            </SectionCard>
          </div>

          <div className="space-y-4">
            {!detail ? (
              <div className="rounded-3xl border border-slate-200 bg-white p-8 text-sm text-slate-500 shadow-sm">
                {loadingDetail ? "正在加载结果详情..." : "未选中结果，正在尝试自动载入第一条结果。"}
              </div>
            ) : (
              <>
                <SectionCard
                  title="结果概览"
                  extra={
                    <div className="flex flex-wrap gap-2">
                      <button
                        onClick={() => handleTabChange("openclaw")}
                        className="rounded-xl border border-violet-300 bg-violet-50 px-4 py-2 text-sm font-medium text-violet-700 hover:bg-violet-100"
                      >
                        打开 OpenClaw
                      </button>
                      <button
                        onClick={() => reloadList(selectedGoalId)}
                        className="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-800 hover:bg-slate-50"
                      >
                        刷新
                      </button>
                      <button
                        onClick={handleExecute}
                        disabled={acting || !activeOutcomeId}
                        className="rounded-xl bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-800 disabled:cursor-not-allowed disabled:opacity-60"
                      >
                        {acting ? "执行中..." : "执行"}
                      </button>
                    </div>
                  }
                >
                  <div className="mb-4 flex flex-wrap gap-2">
                    <Badge tone="purple">{mapGoalTypeLabel(detail.goal.goal_type)}</Badge>
                    <Badge tone={getToneByStatus(detail.outcome_view.status)}>{mapStatusLabel(detail.outcome_view.status)}</Badge>
                    <Badge tone={getToneByStatus(detail.summary.latest_stage)}>{mapStatusLabel(detail.summary.latest_stage)}</Badge>
                    <Badge tone={getToneByStatus(detail.goal.risk_level)}>{detail.goal.risk_level || "unknown"}</Badge>
                    {suggestedTemplate ? <Badge tone="info">推荐 OpenClaw</Badge> : null}
                  </div>

                  {suggestedTemplate ? (
                    <div className="mb-4 rounded-2xl border border-blue-200 bg-blue-50 p-4">
                      <div className="mb-2 flex flex-wrap items-center gap-2">
                        <Badge tone="info">推荐执行方式</Badge>
                        <Badge tone="purple">{suggestedTemplate.templateId}</Badge>
                      </div>
                      <div className="text-sm text-slate-700">{suggestedTemplate.reason}</div>
                      <button
                        onClick={handleApplySuggestedTemplate}
                        className="mt-3 rounded-xl border border-blue-300 bg-white px-4 py-2 text-sm font-medium text-blue-700 hover:bg-blue-100"
                      >
                        应用推荐并打开 OpenClaw
                      </button>
                    </div>
                  ) : null}

                  <KV label="目标 ID" value={detail.goal.id} />
                  <KV label="结果 ID" value={detail.latest_outcome?.id} />
                  <KV label="标题" value={detail.outcome_view.title} />
                  <ExpandableTextRow
                    label="用户目标"
                    value={detail.goal.raw_input}
                    expanded={expandedFields.goal}
                    onToggle={() =>
                      setExpandedFields((prev) => ({ ...prev, goal: !prev.goal }))
                    }
                    minLength={70}
                  />
                  <ExpandableTextRow
                    label="当前结果"
                    value={detail.outcome_view.current_result_summary}
                    expanded={expandedFields.result}
                    onToggle={() =>
                      setExpandedFields((prev) => ({ ...prev, result: !prev.result }))
                    }
                    minLength={90}
                  />
                  <ExpandableTextRow
                    label="下一步行动"
                    value={detail.outcome_view.next_action_summary}
                    expanded={expandedFields.next}
                    onToggle={() =>
                      setExpandedFields((prev) => ({ ...prev, next: !prev.next }))
                    }
                    minLength={90}
                  />
                  <KV label="更新时间" value={formatDate(detail.outcome_view.updated_at)} />

                  <div className="mt-4 flex flex-wrap gap-2">
                    <button
                      onClick={() => copyText(detail.goal.raw_input, "用户目标")}
                      className="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
                    >
                      复制用户目标
                    </button>
                    <button
                      onClick={() => copyText(detail.outcome_view.current_result_summary, "当前结果")}
                      className="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
                    >
                      复制当前结果
                    </button>
                    <button
                      onClick={() => copyText(detail.outcome_view.next_action_summary, "下一步行动")}
                      className="rounded-xl border border-slate-300 bg-white px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50"
                    >
                      复制下一步
                    </button>
                  </div>
                </SectionCard>

                <div className="flex flex-wrap gap-2">
                  <TabButton active={activeTab === "overview"} onClick={() => handleTabChange("overview")}>概览数据</TabButton>
                  <TabButton active={activeTab === "openclaw"} onClick={() => handleTabChange("openclaw")}>OpenClaw</TabButton>
                  <TabButton active={activeTab === "goal"} onClick={() => handleTabChange("goal")}>目标模型</TabButton>
                  <TabButton active={activeTab === "timeline"} onClick={() => handleTabChange("timeline")}>流程事件</TabButton>
                  <TabButton active={activeTab === "executions"} onClick={() => handleTabChange("executions")}>执行记录</TabButton>
                  <TabButton active={activeTab === "artifacts"} onClick={() => handleTabChange("artifacts")}>产物记录</TabButton>
                  <TabButton active={activeTab === "verifications"} onClick={() => handleTabChange("verifications")}>验证记录</TabButton>
                </div>

                {activeTab === "overview" && (
                  <div className="grid gap-6">
                    <SectionCard title="验证摘要">
                      <JsonBlock data={detail.outcome_view.verification_summary} />
                    </SectionCard>
                    <SectionCard title="风险边界">
                      <JsonBlock data={detail.outcome_view.risk_boundary} />
                    </SectionCard>
                  </div>
                )}

                {activeTab === "openclaw" && (
                  <OpenClawPanel
                    selectedTemplateId={selectedTemplateId}
                    setSelectedTemplateId={setSelectedTemplateId}
                    openclawUrl={openclawUrl}
                    setOpenclawUrl={setOpenclawUrl}
                    openclawIssue={openclawIssue}
                    setOpenclawIssue={setOpenclawIssue}
                    openclawAccountHint={openclawAccountHint}
                    setOpenclawAccountHint={setOpenclawAccountHint}
                    onExecute={handleOpenClawExecute}
                    onApplySuggested={handleApplySuggestedTemplate}
                    onApplyPresetScenario={handleApplyPresetScenario}
                    onResetFields={resetOpenClawFields}
                    onClearFields={clearOpenClawFields}
                    onRestoreDraft={restoreLastOpenClawDraft}
                    hasOpenclawDraft={hasOpenclawDraft}
                    executing={openclawActing}
                    disabled={!activeOutcomeId}
                    currentTemplate={currentTemplate}
                    latestOpenclawSummary={latestOpenclawSummary}
                    suggestedTemplate={suggestedTemplate}
                    openclawNotice={openclawNotice}
                  />
                )}

                {activeTab === "goal" && (
                  <SectionCard title="目标模型">
                    <div className="grid gap-4 xl:grid-cols-2">
                      <div>
                        <div className="mb-2 text-sm font-medium text-slate-700">Parsed Goal</div>
                        <JsonBlock data={detail.goal.parsed_goal} />
                      </div>
                      <div>
                        <div className="mb-2 text-sm font-medium text-slate-700">Parser Meta</div>
                        <JsonBlock data={detail.goal.parser_meta} />
                      </div>
                    </div>
                  </SectionCard>
                )}

                {activeTab === "timeline" && (
                  <SectionCard title="流程事件" extra={<Badge tone="info">{timeline.length}</Badge>}>
                    <TimelineList items={timeline} />
                  </SectionCard>
                )}

                {activeTab === "executions" && (
                  <SectionCard title="执行记录" extra={<Badge tone="info">{detail.executions.length}</Badge>}>
                    <ExecutionList items={detail.executions} />
                  </SectionCard>
                )}

                {activeTab === "artifacts" && (
                  <SectionCard title="产物记录" extra={<Badge tone="success">{detail.artifacts.length}</Badge>}>
                    <ArtifactList items={detail.artifacts} />
                  </SectionCard>
                )}

                {activeTab === "verifications" && (
                  <SectionCard title="验证记录" extra={<Badge tone="success">{detail.verifications.length}</Badge>}>
                    <VerificationList items={detail.verifications} />
                  </SectionCard>
                )}
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  );
}
