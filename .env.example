APP_ENV=test
APP_NAME=AutoFabric
APP_HOST=0.0.0.0
APP_PORT=8000

# Database
DATABASE_URL=postgresql+psycopg://postgres:postgres@host.docker.internal:5432/autofabric
POSTGRES_DB=autofabric
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432

# LLM Provider: claude | openai | mock
LLM_PROVIDER=mock
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# OpenClaw Bridge: llm | gateway | shell | mock
OPENCLAW_BRIDGE_MODE=llm
# OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789
# OPENCLAW_GATEWAY_AGENT=main
# OPENCLAW_EXECUTOR_TIMEOUT=120
# OPENCLAW_OUTPUT_DIR=generated
