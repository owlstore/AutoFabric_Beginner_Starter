from __future__ import annotations

from fastapi import APIRouter, Depends, HTTPException
from sqlalchemy.orm import Session

from app.core.db import get_db
from app.services.goal_service import create_goal_and_initial_outcome


router = APIRouter()


@router.post("/entry/submit")
def submit_entry(payload: dict, db: Session = Depends(get_db)):
    raw_input = (payload or {}).get("user_input", "").strip()
    if not raw_input:
        raise HTTPException(status_code=400, detail="user_input 不能为空")

    goal, outcome, parse_result = create_goal_and_initial_outcome(db, raw_input)

    return {
        "goal_id": goal.id,
        "outcome_id": outcome.id,
        "goal_type": goal.goal_type,
        "risk_level": goal.risk_level,
        "parsed_goal": parse_result["parsed_goal"],
        "next_action": parse_result["next_action"],
    }
