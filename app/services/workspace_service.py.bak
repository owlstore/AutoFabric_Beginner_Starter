from __future__ import annotations

from sqlalchemy import select

from app.models.goal import Goal
from app.models.outcome import Outcome


def normalize_parsed_goal(parsed_goal, raw_input: str | None = None) -> dict:
    if not parsed_goal:
        return {
            "intent": "unknown",
            "scope": "unspecified",
            "target": raw_input,
            "source_text": raw_input,
            "parser_meta": {
                "source": "unknown",
                "llm_enabled": False,
            },
        }
    return parsed_goal


def normalize_next_action(next_action) -> dict | None:
    if not next_action:
        return None
    return next_action


def serialize_outcome(outcome: Outcome | None) -> dict | None:
    if not outcome:
        return None

    current_result = outcome.current_result or {}
    next_action = normalize_next_action(outcome.next_action)

    return {
        "id": outcome.id,
        "goal_id": outcome.goal_id,
        "title": outcome.title,
        "status": outcome.status,
        "current_result": current_result,
        "next_action": next_action,
        "risk_boundary": outcome.risk_boundary,
        "created_at": outcome.created_at,
        "updated_at": outcome.updated_at,
    }


def build_workspace_items(db, limit: int = 100) -> list[dict]:
    goals = db.execute(
        select(Goal).order_by(Goal.id.desc()).limit(limit)
    ).scalars().all()

    items = []

    for goal in goals:
        latest_outcome = db.execute(
            select(Outcome)
            .where(Outcome.goal_id == goal.id)
            .order_by(Outcome.id.desc())
            .limit(1)
        ).scalars().first()

        parsed_goal = normalize_parsed_goal(goal.parsed_goal, raw_input=goal.raw_input)
        latest_outcome_data = serialize_outcome(latest_outcome) if latest_outcome else None

        current_result = (latest_outcome.current_result or {}) if latest_outcome else {}
        next_action = (latest_outcome.next_action or {}) if latest_outcome else {}

        items.append(
            {
                "goal_id": goal.id,
                "title": goal.raw_input,
                "goal_type": goal.goal_type,
                "risk_level": goal.risk_level,
                "scope": parsed_goal.get("scope"),
                "parser_meta": parsed_goal.get("parser_meta"),
                "stage": current_result.get("stage"),
                "step_type": next_action.get("step_type"),
                "execution_hint_available": bool(next_action),
                "executor_touched": "last_executor_run" in current_result,
                "executor_result_available": bool(
                    current_result.get("artifact") or current_result.get("verification")
                ),
                "recommendation_reason_available": bool(next_action.get("summary")),
                "flow_event_count": 0,
                "created_at": goal.created_at,
                "updated_at": latest_outcome.updated_at if latest_outcome else goal.created_at,
                "latest_outcome": latest_outcome_data,
            }
        )

    return items