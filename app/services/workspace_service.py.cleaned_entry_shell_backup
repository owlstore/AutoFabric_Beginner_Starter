from __future__ import annotations

from typing import Any

from sqlalchemy import select

from app.models.goal import Goal
from app.models.outcome import Outcome


def _normalize_dict_like(value: Any, *, default: dict | None = None) -> dict:
    if isinstance(value, dict):
        return value
    return default.copy() if default else {}


def _normalize_next_action(value: Any) -> dict[str, Any]:
    import json

    if isinstance(value, dict):
        return value

    if isinstance(value, str):
        text = value.strip()
        if not text:
            return {
                "summary": None,
                "step_type": None,
                "steps": [],
                "requires_human_confirmation": False,
            }

        try:
            parsed = json.loads(text)
            if isinstance(parsed, dict):
                return parsed
        except Exception:
            pass

        return {
            "summary": value,
            "step_type": None,
            "steps": [],
            "requires_human_confirmation": False,
        }

    return {
        "summary": None,
        "step_type": None,
        "steps": [],
        "requires_human_confirmation": False,
    }

def normalize_parsed_goal(parsed_goal: Any, raw_input: str | None = None) -> dict[str, Any]:
    if isinstance(parsed_goal, dict):
        return parsed_goal

    if isinstance(parsed_goal, str):
        return {
            "intent": "unknown",
            "scope": "unspecified",
            "target": raw_input,
            "source_text": raw_input,
            "parser_meta": {
                "source": "legacy_string",
                "llm_enabled": False,
            },
        }

    return {
        "intent": "unknown",
        "scope": "unspecified",
        "target": raw_input,
        "source_text": raw_input,
        "parser_meta": {
            "source": "unknown",
            "llm_enabled": False,
        },
    }


def normalize_next_action(next_action: Any) -> dict[str, Any] | None:
    if next_action is None:
        return None
    return _normalize_next_action(next_action)


def serialize_outcome(outcome: Outcome | None) -> dict[str, Any] | None:
    if not outcome:
        return None

    current_result = _normalize_dict_like(outcome.current_result)
    next_action = normalize_next_action(outcome.next_action)

    return {
        "id": outcome.id,
        "goal_id": outcome.goal_id,
        "title": outcome.title,
        "status": outcome.status,
        "current_result": current_result,
        "next_action": next_action,
        "risk_boundary": outcome.risk_boundary,
        "created_at": outcome.created_at,
        "updated_at": outcome.updated_at,
    }


def build_workspace_items(db, limit: int = 100) -> list[dict[str, Any]]:
    goals = db.execute(
        select(Goal).order_by(Goal.id.desc()).limit(limit)
    ).scalars().all()

    items: list[dict[str, Any]] = []

    for goal in goals:
        latest_outcome = db.execute(
            select(Outcome)
            .where(Outcome.goal_id == goal.id)
            .order_by(Outcome.id.desc())
            .limit(1)
        ).scalars().first()

        parsed_goal = normalize_parsed_goal(goal.parsed_goal, raw_input=goal.raw_input)
        latest_outcome_data = serialize_outcome(latest_outcome) if latest_outcome else None

        current_result = (
            _normalize_dict_like(latest_outcome.current_result) if latest_outcome else {}
        )
        next_action = (
            _normalize_next_action(latest_outcome.next_action) if latest_outcome else {}
        )

        items.append(
            {
                "goal_id": goal.id,
                "title": goal.raw_input,
                "goal_type": goal.goal_type,
                "risk_level": goal.risk_level,
                "scope": parsed_goal.get("scope"),
                "parser_meta": parsed_goal.get("parser_meta"),
                "stage": current_result.get("stage"),
                "step_type": next_action.get("step_type"),
                "execution_hint_available": bool(next_action),
                "executor_touched": "last_executor_run" in current_result,
                "executor_result_available": bool(
                    current_result.get("artifact") or current_result.get("verification")
                ),
                "recommendation_reason_available": bool(next_action.get("summary")),
                "flow_event_count": 0,
                "created_at": goal.created_at,
                "updated_at": latest_outcome.updated_at if latest_outcome else goal.created_at,
                "latest_outcome": latest_outcome_data,
            }
        )

    return items