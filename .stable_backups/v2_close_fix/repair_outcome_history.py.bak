from __future__ import annotations

import sys
from pathlib import Path

PROJECT_ROOT = Path(__file__).resolve().parent.parent
if str(PROJECT_ROOT) not in sys.path:
    sys.path.insert(0, str(PROJECT_ROOT))

import json
from typing import Any

from sqlalchemy import select, func
from sqlalchemy.orm import Session

from app.core.db import SessionLocal
from app.models.outcome import Outcome
from app.models.flow_event import FlowEvent


def parse_json_like(value: Any) -> Any:
    if value is None:
        return None
    if isinstance(value, (dict, list)):
        return value
    if isinstance(value, str):
        text = value.strip()
        if not text:
            return None
        try:
            return json.loads(text)
        except Exception:
            return value
    return value


def ensure_dict(value: Any) -> dict[str, Any]:
    parsed = parse_json_like(value)
    return parsed if isinstance(parsed, dict) else {}


def main() -> None:
    db: Session = SessionLocal()

    fixed_stage_count = 0
    fixed_summary_count = 0
    created_initial_event_count = 0
    created_completed_event_count = 0

    try:
        outcomes = db.execute(
            select(Outcome).order_by(Outcome.id.asc())
        ).scalars().all()

        for outcome in outcomes:
            changed = False

            current_result = ensure_dict(outcome.current_result)

            status = (outcome.status or "").strip()

            # 1) 修 current_result.stage
            stage = current_result.get("stage")
            if status == "draft":
                expected_stage = "goal_captured"
            elif status == "completed":
                expected_stage = "analysis_context_collected"
            else:
                expected_stage = stage or "goal_captured"

            if current_result.get("stage") != expected_stage:
                current_result["stage"] = expected_stage
                fixed_stage_count += 1
                changed = True

            # 2) 修 current_result.summary
            summary = current_result.get("summary")
            if not summary:
                if status == "draft":
                    current_result["summary"] = "Goal captured. Execution not started yet."
                elif status == "completed":
                    current_result["summary"] = "System understanding context collected."
                else:
                    current_result["summary"] = "Outcome state synchronized."
                fixed_summary_count += 1
                changed = True

            if changed:
                outcome.current_result = current_result
                db.add(outcome)

            # 3) 查 flow events
            events = db.execute(
                select(FlowEvent)
                .where(FlowEvent.outcome_id == outcome.id)
                .order_by(FlowEvent.id.asc())
            ).scalars().all()

            has_goal_created = any(e.trigger_type == "goal_created" for e in events)
            has_execute_completed = any(
                e.trigger_type == "execute_outcome" and e.to_status == "completed"
                for e in events
            )

            # 4) 没有任何事件，补初始 draft 事件
            if not events and not has_goal_created:
                init_event = FlowEvent(
                    outcome_id=outcome.id,
                    from_status=None,
                    to_status="draft" if status != "completed" else "draft",
                    trigger_type="goal_created",
                    note="Backfilled initial outcome event.",
                )
                db.add(init_event)
                created_initial_event_count += 1

            # 5) completed 但没有完成事件，补完成事件
            if status == "completed" and not has_execute_completed:
                completed_event = FlowEvent(
                    outcome_id=outcome.id,
                    from_status="draft",
                    to_status="completed",
                    trigger_type="execute_outcome",
                    note="Backfilled completed event.",
                )
                db.add(completed_event)
                created_completed_event_count += 1

        db.commit()

        print("=== repair summary ===")
        print(f"fixed_stage_count={fixed_stage_count}")
        print(f"fixed_summary_count={fixed_summary_count}")
        print(f"created_initial_event_count={created_initial_event_count}")
        print(f"created_completed_event_count={created_completed_event_count}")
        print("repair done")

    except Exception:
        db.rollback()
        raise
    finally:
        db.close()


if __name__ == "__main__":
    main()
