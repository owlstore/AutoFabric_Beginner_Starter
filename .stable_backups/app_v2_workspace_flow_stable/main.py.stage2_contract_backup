from __future__ import annotations

import json
from typing import Any


def _parse_json_like(value: Any) -> Any:
    if isinstance(value, str):
        try:
            return json.loads(value)
        except Exception:
            return value
    return value


def normalize_parser_meta(value: Any, default_source: str = "legacy", default_llm_enabled: Any = None) -> dict[str, Any]:
    parsed = _parse_json_like(value)
    if not isinstance(parsed, dict):
        parsed = {}

    return {
        "source": parsed.get("source", default_source),
        "llm_enabled": parsed.get("llm_enabled", default_llm_enabled),
    }


def normalize_parsed_goal(value: Any, raw_input: str = "", default_source: str = "legacy", default_llm_enabled: Any = None) -> dict[str, Any]:
    parsed = _parse_json_like(value)
    if not isinstance(parsed, dict):
        parsed = {}

    return {
        "intent": parsed.get("intent") or "general_task",
        "scope": parsed.get("scope") or "unspecified",
        "target": parsed.get("target") or (raw_input.strip() if raw_input else "unclear request"),
        "source_text": parsed.get("source_text") or raw_input,
        "parser_meta": normalize_parser_meta(
            parsed.get("parser_meta"),
            default_source=default_source,
            default_llm_enabled=default_llm_enabled,
        ),
    }


def normalize_next_action(value: Any) -> dict[str, Any]:
    parsed = _parse_json_like(value)

    if isinstance(parsed, dict):
        return {
            "summary": parsed.get("summary") or "Pending next action.",
            "step_type": parsed.get("step_type"),
            "steps": parsed.get("steps") if isinstance(parsed.get("steps"), list) else [],
            "requires_human_confirmation": bool(parsed.get("requires_human_confirmation", False)),
        }

    if isinstance(parsed, str):
        text = parsed.strip()
        return {
            "summary": text or "Pending next action.",
            "step_type": None,
            "steps": [],
            "requires_human_confirmation": False,
        }

    return {
        "summary": "Pending next action.",
        "step_type": None,
        "steps": [],
        "requires_human_confirmation": False,
    }


def build_default_next_action(goal_type: str, parsed_goal: dict[str, Any]) -> dict[str, Any]:
    intent = parsed_goal.get("intent")
    target = parsed_goal.get("target") or "current target"

    if goal_type == "system_understanding" or intent == "understand_system":
        return {
            "summary": f"Analyze {target} and prepare an understanding outcome.",
            "step_type": "analyze_system",
            "steps": [
                "Collect project assets",
                "Identify core modules",
                "Document system behavior",
            ],
            "requires_human_confirmation": False,
        }

    if goal_type == "bug_fix":
        return {
            "summary": "Collect error context and create a repair outcome.",
            "step_type": "collect_context",
            "steps": [
                "Collect error logs",
                "Locate affected module",
                "Prepare repair outcome",
            ],
            "requires_human_confirmation": False,
        }

    if goal_type == "system_build":
        return {
            "summary": "Create the first build outcome and define delivery scope.",
            "step_type": "define_build_scope",
            "steps": [
                "Clarify delivery scope",
                "Define first MVP boundary",
                "Prepare first build outcome",
            ],
            "requires_human_confirmation": False,
        }

    return {
        "summary": "Clarify the request before proceeding.",
        "step_type": "clarify_goal",
        "steps": [
            "Clarify the user's goal",
            "Confirm the scope",
            "Prepare the first actionable outcome",
        ],
        "requires_human_confirmation": False,
    }


def build_initial_current_result(goal_type: str) -> dict[str, Any]:
    if goal_type == "system_understanding":
        return {
            "stage": "goal_captured",
            "summary": "Goal captured. System analysis not started yet.",
            "analysis_started": False,
        }

    if goal_type == "bug_fix":
        return {
            "stage": "goal_captured",
            "summary": "Goal captured. Bug investigation not started yet.",
            "error_context_collected": False,
        }

    if goal_type == "system_build":
        return {
            "stage": "goal_captured",
            "summary": "Goal captured. Build workflow not started yet.",
            "delivery_scope_defined": False,
        }

    return {
        "stage": "goal_captured",
        "summary": "Goal captured. Execution not started yet.",
    }


def normalize_goal_payload(parsed: dict[str, Any], raw_input: str = "") -> dict[str, Any]:
    parsed_goal_raw = parsed.get("parsed_goal") or {}
    goal_type = parsed.get("goal_type") or "general_task"
    risk_level = parsed.get("risk_level") or "low"

    parser_meta_guess = parsed_goal_raw.get("parser_meta") if isinstance(parsed_goal_raw, dict) else None
    source = "legacy"
    llm_enabled = None
    if isinstance(parser_meta_guess, dict):
        source = parser_meta_guess.get("source", "legacy")
        llm_enabled = parser_meta_guess.get("llm_enabled", None)

    parsed_goal = normalize_parsed_goal(
        parsed_goal_raw,
        raw_input=raw_input,
        default_source=source,
        default_llm_enabled=llm_enabled,
    )

    next_action = normalize_next_action(parsed.get("recommended_next_action"))
    if not next_action.get("summary"):
        next_action = build_default_next_action(goal_type, parsed_goal)

    return {
        "raw_input": raw_input or parsed.get("raw_input") or "",
        "parsed_goal": parsed_goal,
        "goal_type": goal_type,
        "risk_level": risk_level,
        "recommended_next_action": next_action,
    }