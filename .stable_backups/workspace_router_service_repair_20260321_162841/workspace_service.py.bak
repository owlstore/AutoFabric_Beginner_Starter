from __future__ import annotations

from collections import Counter
from typing import Any

from sqlmodel import Session, select

from app.db.session import engine
from app.models.execution import Execution
from app.models.flow_event import FlowEvent
from app.models.goal import Goal
from app.models.outcome import Outcome
from app.services.serializer_service import serialize_outcome_for_workspace
from app.services.stage_service import map_stage


def _parse_json_like(value: Any) -> dict[str, Any]:
    return value if isinstance(value, dict) else {}


def list_workspaces(
    *,
    goal_type: str | None = None,
    status: str | None = None,
    stage: str | None = None,
    risk_level: str | None = None,
) -> dict[str, Any]:
    with Session(engine) as session:
        goals = session.exec(select(Goal).order_by(Goal.id.desc())).all()
        goal_ids = [g.id for g in goals]

        outcomes = session.exec(select(Outcome).where(Outcome.goal_id.in_(goal_ids))).all() if goal_ids else []
        executions = session.exec(select(Execution).where(Execution.outcome_id.in_([o.id for o in outcomes]))).all() if outcomes else []
        flow_events = session.exec(select(FlowEvent).where(FlowEvent.outcome_id.in_([o.id for o in outcomes]))).all() if outcomes else []

    latest_outcome_by_goal: dict[int, Outcome] = {}
    for outcome in outcomes:
        existing = latest_outcome_by_goal.get(outcome.goal_id)
        if existing is None or outcome.id > existing.id:
            latest_outcome_by_goal[outcome.goal_id] = outcome

    execution_by_outcome: dict[int, list[Execution]] = {}
    for item in executions:
        execution_by_outcome.setdefault(item.outcome_id, []).append(item)

    flow_count_by_outcome: dict[int, int] = {}
    for item in flow_events:
        flow_count_by_outcome[item.outcome_id] = flow_count_by_outcome.get(item.outcome_id, 0) + 1

    items: list[dict[str, Any]] = []

    for goal in goals:
        parsed_goal = _parse_json_like(goal.parsed_goal)
        parser_meta = parsed_goal.get("parser_meta") if isinstance(parsed_goal, dict) else None
        latest_outcome = latest_outcome_by_goal.get(goal.id)

        if goal_type and goal.goal_type != goal_type:
            continue
        if risk_level and goal.risk_level != risk_level:
            continue
        if status and latest_outcome and latest_outcome.status != status:
            continue
        if status and not latest_outcome:
            continue

        current_result = _parse_json_like(latest_outcome.current_result) if latest_outcome else {}
        next_action = _parse_json_like(latest_outcome.next_action) if latest_outcome else {}
        current_stage = current_result.get("stage")

        stage_info = map_stage(
            raw_stage=current_stage,
            outcome_status=latest_outcome.status if latest_outcome else None,
            current_result=current_result,
            next_action=next_action,
        )
        normalized_stage = stage_info["stage_key"]

        if stage and normalized_stage != stage and current_stage != stage:
            continue

        latest_outcome_data = serialize_outcome_for_workspace(latest_outcome) if latest_outcome else None
        outcome_executions = execution_by_outcome.get(latest_outcome.id, []) if latest_outcome else []

        items.append(
            {
                "goal_id": goal.id,
                "title": getattr(goal, "title", None) or goal.raw_input,
                "goal_type": goal.goal_type,
                "risk_level": goal.risk_level,
                "scope": parsed_goal.get("scope") if isinstance(parsed_goal, dict) else None,
                "parser_meta": parser_meta,
                "stage": normalized_stage,
                "raw_stage": current_stage,
                "stage_key": normalized_stage,
                "stage_label": stage_info["stage_label"],
                "step_type": parsed_goal.get("intent") if isinstance(parsed_goal, dict) else None,
                "execution_hint_available": latest_outcome is not None,
                "executor_touched": len(outcome_executions) > 0,
                "executor_result_available": bool(current_result),
                "recommendation_reason_available": bool(next_action),
                "flow_event_count": flow_count_by_outcome.get(latest_outcome.id, 0) if latest_outcome else 0,
                "created_at": getattr(goal, "created_at", None),
                "updated_at": getattr(latest_outcome, "updated_at", None) if latest_outcome else getattr(goal, "created_at", None),
                "latest_outcome": latest_outcome_data,
            }
        )

    stage_counts_counter = Counter((item.get("stage_key") or "unknown") for item in items)
    stage_counts = {
        "requirement": stage_counts_counter.get("requirement", 0),
        "clarification": stage_counts_counter.get("clarification", 0),
        "prototype": stage_counts_counter.get("prototype", 0),
        "orchestration": stage_counts_counter.get("orchestration", 0),
        "execution": stage_counts_counter.get("execution", 0),
        "testing": stage_counts_counter.get("testing", 0),
        "delivery": stage_counts_counter.get("delivery", 0),
        "unknown": stage_counts_counter.get("unknown", 0),
    }

    return {
        "items": items,
        "count": len(items),
        "stage_counts": stage_counts,
        "filters": {
            "goal_type": goal_type,
            "status": status,
            "stage": stage,
            "risk_level": risk_level,
        },
    }
