{
  "name": "autofabric_beginner_starter",
  "version": "1.0.0",
  "description": "这是给 macOS + 本地 OpenClaw 用户准备的最小可运行起点。",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev:up": "bash scripts/dev_workbench_up.sh",
    "dev:status": "bash scripts/dev_workbench_status.sh",
    "dev:down": "bash scripts/dev_workbench_down.sh",
    "dev:where": "bash scripts/check_frontend_entry.sh",
    "gate:e2e": "bash scripts/40_e2e_workbench_gate.sh",
    "gate:templates": "bash scripts/41_template_kit_gate.sh",
    "frontend:dev": "npm --prefix frontend run dev -- --host 127.0.0.1 --port 5173",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:e2e": "npm --prefix frontend run test:e2e",
    "frontend:e2e:smoke": "npm --prefix frontend run test:e2e:smoke",
    "frontend:e2e:fullflow": "npm --prefix frontend run test:e2e:fullflow",
    "frontend:lint": "npm --prefix frontend run lint",
    "quark:dev": "pnpm --dir quark-browser dev",
    "quark:build": "pnpm --dir quark-browser build",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/owlstore/AutoFabric_Beginner_Starter.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/owlstore/AutoFabric_Beginner_Starter/issues"
  },
  "homepage": "https://github.com/owlstore/AutoFabric_Beginner_Starter#readme",
  "devDependencies": {
    "react-scripts": "^5.0.1",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "axios": "^1.13.6"
  }
}
